----------------------------EXAMPLE 1

SELECT Surname, Balance
FROM Customers
WHERE Balance > (
    SELECT AVG(Balance) 
    FROM Customers
);

--EXERCISE 1

SELECT Surname, CreditScore
FROM Customers
WHERE CreditScore > (
    SELECT AVG(CreditScore)
    FROM Customers
);

--EXERCISE 2

SELECT Surname, Geography, EstimatedSalary
FROM Customers
WHERE EstimatedSalary = (
    SELECT MAX(EstimatedSalary)
    FROM Customers
); 

----------------------------EXAMPLE 2

SELECT Geography,
       COUNT(CustomerId) AS Total_Clients,
       SUM(CASE WHEN Exited = 1 THEN 1 ELSE 0 END) AS Churned_Clients,
       (SUM(CASE WHEN Exited = 1 THEN 1 ELSE 0 END) * 100.0 / COUNT(CustomerId)) AS Churn_Rate_Percent
FROM Customers
GROUP BY Geography;

--EXERCISE 1

SELECT Geography,
		COUNT(CustomerId) AS Total_Clients,
		SUM(CASE WHEN HasCrCard = 1 THEN 1 ELSE 0 END) AS Clients_With_Card,
		(SUM(CASE WHEN HasCrCard = 1 THEN 1 ELSE 0 END) * 100.0 / COUNT(CustomerId)) AS Credit_Card_Adoption_Rate
FROM Customers
GROUP BY Geography;

-EXERCISE 2

SELECT Gender,
		COUNT(CustomerId) AS Total_Clients,
		SUM(CASE WHEN IsActiveMember = 1 THEN 1 ELSE 0 END) AS Activity_Membership,
		(SUM(CASE WHEN IsActiveMember = 1 THEN 1 ELSE 0 END) * 100.0 / COUNT(CustomerId)) AS Activity_Rate
FROM Customers
GROUP BY Gender;

----------------------------EXAMPLE 3

SELECT Geography,
    ROUND(AVG(Balance), 2) AS Media_Sold
FROM Customers
GROUP BY Geography
ORDER BY Media_Sold DESC;

--EXERCISE 1

SELECT Gender,
	ROUND(AVG(CreditScore), 2) AS AVG_Credit_Score
FROM Customers
GROUP BY Gender
ORDER BY AVG_Credit_Score DESC;

--EXERCISE 2

SELECT Tenure,
	ROUND(AVG(EstimatedSalary), 2) AS AVG_Estimated_Salary
FROM Customers
GROUP BY Tenure
ORDER BY AVG_Estimated_Salary DESC;

----------------------------EXAMPLE 4 

SELECT 
    Geography,
    ROUND(
        (SUM(CASE WHEN Exited = 1 THEN 1 ELSE 0 END) * 100.0 / COUNT(CustomerId)), 
        2
    ) AS Rate_Churn_Percentage
FROM Customers
GROUP BY Geography
ORDER BY Rate_Churn_Percentage DESC;

