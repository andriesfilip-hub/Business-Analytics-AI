----------------------------EXAMPLE 6

SELECT 
    CASE 
        WHEN Balance = 0 THEN 'No Balance' 
        ELSE 'With Balance' 
    END AS Balance_Category,
    ROUND(AVG(Age), 1) AS AVG_Age
FROM Customers
WHERE Geography = 'France'
GROUP BY Balance_Category
ORDER BY AVG_Age DESC;

--EXERCISE 1

SELECT
	CASE
		WHEN Age <30 THEN 'Young'
		ELSE 'Senior'
	END AS Age_Category_with_Card,
	ROUND(AVG(CreditScore), 1) AS AVG_Credit_Score
FROM Customers
WHERE HasCrCard = 1
GROUP BY Age_Category_with_Card
ORDER BY AVG_Credit_Score DESC;

--EXERCISE 2

SELECT
	CASE
		WHEN Tenure < 5 THEN 'New Client'
		ELSE 'Old Client'
	END AS Client_Category_Active,
	ROUND(AVG(Balance), 2) AS AVG_Balance
FROM Customers
WHERE IsActiveMember = 1
GROUP BY Client_Category_Active
ORDER BY AVG_Balance DESC;

----------------------------EXAMPLE 7

SELECT 
    Surname,
    EstimatedSalary,
    ROW_NUMBER() OVER (ORDER BY EstimatedSalary DESC) AS Top_In_Place
FROM Customers
WHERE Geography = 'France'
ORDER BY Top_In_Place ASC;

--EXERCISE 1

SELECT
	Surname,
	CreditScore,
	ROW_NUMBER() OVER (ORDER BY CreditScore DESC) AS Top_CrScore
FROM Customers
WHERE Geography = 'Germany'
ORDER BY Top_CrScore ASC;

--EXERCISE 2

SELECT 
	Surname,
	Balance,
