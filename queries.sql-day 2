--EXAMPLE 1

SELECT Geography, 
       COUNT(CustomerId) AS Total_Clients, 
       AVG(CreditScore) AS Average_Credit_Score, 
       MAX(EstimatedSalary) AS Max_Salary
FROM Customers
GROUP BY Geography;

--EXERCISE 1

SELECT Gender,
     COUNT(CustomerId) AS Total_Customers,
     AVG(Balance) AS Average_Balance
FROM Customers
GROUP BY Gender;

--EXERCISE 2

SELECT HasCrCard,
    COUNT(CustomerId) AS Total_Customers,
    AVG(Tenure) AS Average_Tenure
FROM Customers
GROUP BY HasCrCard 


